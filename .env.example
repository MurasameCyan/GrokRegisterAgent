# ============================================
# Grok Register Agent 环境变量示例
# 复制为 .env 后配合根目录 docker compose 使用：
#   cp .env.example .env
#   docker compose up -d
# ============================================

# Web UI 暴露到宿主机的端口
WEB_PORT=6657

# GHCR 镜像（fork 默认本仓库 owner；可改回上游）
# GROK_IMAGE=ghcr.io/hkxiaoyao/grokregisteragent:beta
# SOLVER_IMAGE=ghcr.io/hkxiaoyao/grok-turnstile-solver:beta

# 注册轮数默认值
RUN_COUNT=10

# 邮件后端（兼容 dreamhunter2333/cloudflare_temp_email）
# MAIL_API_BASE：cloudflare_temp_email 后端 Worker/API 根地址
# MAIL_ADMIN_AUTH：网站 admin 密码，用于 x-admin-auth
# MAIL_DOMAIN：已配置并可收信的域名
MAIL_API_BASE=
MAIL_ADMIN_AUTH=
MAIL_DOMAIN=

# 可选代理
HTTP_PROXY=
BROWSER_PROXY=

# 使用 HTTPS 反向代理访问时可设为 1；直接 http://IP:6657 部署请留空
COOKIE_SECURE=

# Web 鉴权默认账号密码会打印在 docker logs 中：admin/admin
# 首次登录后 WebUI 会强制修改账号密码

# --------------------------------------------
# register 热更新（一般无需改，compose 已配置）
# 宿主 ./register 挂到 /opt/register-host 后，entrypoint 自动同步到 /app/register
# REGISTER_HOST_SRC=/opt/register-host
# REGISTER_SEED=/opt/register-seed
# REGISTER_DIR=/app/register

# --------------------------------------------
# 可选：本地 Turnstile Solver 子容器（默认不拉取）
# multi-arch：linux/amd64 + linux/arm64（chromium；非 camoufox）
# 启动：docker compose --profile solver up -d
# 或设置：COMPOSE_PROFILES=solver
# 设置页「外置 Turnstile Solver」开关 + 探活图标
# ARM 可跑；Turnstile 通过率通常仍低于 x86
# --------------------------------------------
# COMPOSE_PROFILES=
TURNSTILE_SOLVER_ENABLED=0
TURNSTILE_SOLVER_URL=http://turnstile-solver:5072
TURNSTILE_SOLVER_THREADS=2
TURNSTILE_SOLVER_BROWSER=chromium
# TURNSTILE_SOLVER_DEBUG=0
# TURNSTILE_SOLVER_PROXY=0
# 可选第三方打码（有 key 时外解可走 YesCaptcha）
YESCAPTCHA_KEY=
