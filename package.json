{
  "name": "grok-register-agent",
  "version": "1.0.0",
  "description": "Grok Register Agent — 可自部署的 Grok 注册机 Web 控制台，支持 Docker、DrissionPage、邮件后端与本地号池。",
  "keywords": [
    "grok",
    "grok注册机",
    "xai",
    "xai自动化",
    "drissionpage",
    "docker",
    "自部署",
    "webui",
    "账号号池",
    "注册工具"
  ],
  "private": false,
  "author": "MurasameCyan",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/MurasameCyan/GrokRegisterAgent",
  "repository": {
    "type": "git",
    "url": "https://github.com/MurasameCyan/GrokRegisterAgent.git"
  },
  "bugs": {
    "url": "https://github.com/MurasameCyan/GrokRegisterAgent/issues"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "server:build": "vite build && tsc -p server/tsconfig.json && tsc-alias -p server/tsconfig.json",
    "server:dev": "tsx watch server/src/index.ts",
    "server:start": "node server/dist/server/src/index.js",
    "server:start:8098": "cross-env PORT=8098 node server/dist/server/src/index.js"
  },
  "dependencies": {
    "@fontsource/dancing-script": "^5.2.8",
    "@fontsource/great-vibes": "^5.2.8",
    "axios": "^1.17.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "4.21.0",
    "https-proxy-agent": "^9.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "0.453.0",
    "socks-proxy-agent": "^8.0.5",
    "tailwind-merge": "2.5.4",
    "ws": "8.18.0",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@types/ws": "8.5.12",
    "@vitejs/plugin-react": "4.3.2",
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "postcss": "8.4.47",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.13",
    "tsc-alias": "1.8.10",
    "tsx": "4.19.1",
    "typescript": "5.6.2",
    "vite": "5.4.8"
  }
}
